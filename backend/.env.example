# Copy this file to .env and fill in your real values.
# .env is gitignored so secrets stay out of version control.

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Database → Connect → Drivers
# Replace <password> with your database user password.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/growincome?retryWrites=true&w=majority

# Optional: override the port (Render sets this automatically)
# PORT=3000
